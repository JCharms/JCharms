# ── Edge Function secrets (LOCAL dev) ──
# Copy to `supabase/functions/.env` and run:
#   supabase functions serve --env-file ./supabase/functions/.env
#
# In production set these with:
#   supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=... etc.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the CLI locally and by the platform in production.

RAZORPAY_KEY_ID=rzp_test_xxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RESEND_API_KEY=re_xxxxxxxxxxxxxx
ORDER_EMAIL_FROM=J Charms <orders@jcharms.in>
