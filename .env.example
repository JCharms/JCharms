# ─────────────────────────────────────────────────────────────────────────
# J Charms — environment variables
# Copy to `.env` and fill in. Only VITE_* vars are exposed to the browser.
# NEVER put a service-role key or any secret in a VITE_* var.
# ─────────────────────────────────────────────────────────────────────────

# ── Client (safe to expose — anon key is protected by RLS) ──
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Canonical public origin, no trailing slash. Every link in a Supabase auth
# email (confirm signup, reset password) is built from this.
#
# Leave BLANK for local dev — it falls back to whatever origin you're on.
# SET IT in production (Netlify → Site settings → Environment variables), and
# add the same URL to Supabase → Authentication → URL Configuration as both the
# Site URL and a Redirect URL. Miss either half and confirmation emails fall
# back to the Site URL default (http://localhost:3000).
# VITE_SITE_URL=https://jcharms.netlify.app

# ── Edge Functions only (set via `supabase secrets set`, NOT in this file
#    for production). Listed here purely as documentation. ──
# SUPABASE_SERVICE_ROLE_KEY=...        # full DB access — server-side only
# RAZORPAY_KEY_ID=...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RESEND_API_KEY=...
# ORDER_EMAIL_FROM="J Charms <orders@jcharms.example>"
